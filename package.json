    "discord-api-types": "^0.38.47",
    "discord.js": "^14.22.1",
    "elevenlabs-js": "^1.2.6",
    "ffmpeg": "^0.0.4",
    "ffmpeg-static": "^5.3.0",
    "fs": "^0.0.1-security",
    "isbot": "^4.1.0",
    "opusscript": "^0.0.8",
    "path": "^0.12.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tiny-invariant": "^1.3.3",
    "url": "^0.11.4",
    "uuid": "^14.0.0"
