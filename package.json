    "release:major": "npm version major",
    "typecheck": "tsc && tsc -p tsconfig.json --noEmit",
    "typecheck:bot": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@elevenlabs/elevenlabs-js": "^2.53.0",
