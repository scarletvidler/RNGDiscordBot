{
  "name": "lerche-discord-bot",
  "version": "1.3.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "start:bot": "tsx watch server.js",
    "start:bot:dev": "tsx watch --env-file=.env.development server.js",
